---
permalink: /api/site-index.json
eleventyExcludeFromCollections: true
---
{
  "generated": "{{ siteIndex.generated }}",
  "resources": {{ siteIndex.resources | dump | safe }},
  "stories": {{ siteIndex.stories | dump | safe }},
  "spotlights": {{ siteIndex.spotlights | dump | safe }},
  "taxonomies": {{ siteIndex.taxonomies | dump | safe }},
  "blog": [
    {%- for post in collections.blogPosts %}
    {
      "title": "{{ post.data.title | jsonEscape }}",
      "date": "{{ post.date | dateISO }}",
      "category": "{{ post.data.category | jsonEscape }}",
      "autoGenerated": {% if post.data.autoGenerated %}true{% else %}false{% endif %}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
