---
layout: layouts/base.njk
title: Submit a Resource
description: "Help us grow our directory by submitting a resource you know about."
permalink: /submit-resource/
---

<section class="py-16">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold mb-4 text-center" style="color: var(--color-primary);">Submit a Resource</h1>
    <p class="text-center mb-12" style="color: var(--color-text-light);">
      Know of a program, service, or organization that supports individuals with disabilities? Help us build a more complete directory by sharing it below.
    </p>

    <form action="https://formspree.io/f/{{ site.formspree.submitResource }}" method="POST" class="space-y-6">
      <div>
        <label for="resource-name" class="block text-sm font-semibold mb-2">Resource/Organization Name *</label>
        <input type="text" id="resource-name" name="resourceName" required class="form-input" placeholder="Name of the resource or organization">
      </div>
      <div>
        <label for="resource-website" class="block text-sm font-semibold mb-2">Website</label>
        <input type="url" id="resource-website" name="website" class="form-input" placeholder="https://...">
      </div>
      <div>
        <label for="resource-location" class="block text-sm font-semibold mb-2">Location *</label>
        <select id="resource-location" name="location" required class="form-input">
          <option value="">Select location...</option>
          <option value="National">National</option>
          {% for state in states %}
          <option value="{{ state.name }}">{{ state.name }}</option>
          {% endfor %}
        </select>
      </div>
      <div>
        <label for="resource-category" class="block text-sm font-semibold mb-2">Category *</label>
        <select id="resource-category" name="category" required class="form-input">
          <option value="">Select category...</option>
          <option value="therapy">Therapy Providers</option>
          <option value="equipment">Equipment & Adaptive Gear</option>
          <option value="education">Education & IEP</option>
          <option value="recreation">Recreation & Activities</option>
          <option value="respite">Respite Care</option>
          <option value="employment">Employment</option>
          <option value="nonprofit">Non-Profits & Foundations</option>
          <option value="faith">Faith Communities</option>
          <option value="sensory">Sensory-Friendly Venues</option>
          <option value="childcare">Childcare</option>
          <option value="legal">Legal & Advocacy</option>
          <option value="clothing">Adaptive Clothing</option>
          <option value="community">Community Groups</option>
          <option value="government">Government Services</option>
          <option value="early-intervention">Early Intervention (0-3)</option>
          <option value="transition">Transition Services (18-21+)</option>
          <option value="financial">Financial Assistance & Benefits</option>
          <option value="insurance">Insurance & Appeals</option>
          <option value="planning">Special Needs Planning</option>
          <option value="mental-health">Mental Health</option>
          <option value="transportation">Transportation</option>
          <option value="housing">Housing</option>
          <option value="medical">Medical Providers</option>
          <option value="camps">Camps & After-School</option>
          <option value="sibling-support">Sibling Support</option>
          <option value="assistive-tech">Assistive Technology</option>
          <option value="sports">Adaptive Sports & Fitness</option>
          <option value="emergency">Emergency Preparedness</option>
          <option value="home-modifications">Home Modifications</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label for="resource-description" class="block text-sm font-semibold mb-2">Description *</label>
        <textarea id="resource-description" name="description" rows="4" required class="form-input" placeholder="What does this resource offer? Who does it serve?"></textarea>
      </div>
      <div>
        <label for="resource-contact" class="block text-sm font-semibold mb-2">Contact Information</label>
        <input type="text" id="resource-contact" name="contactInfo" class="form-input" placeholder="Phone, email, or address">
      </div>
      <div>
        <label for="submitter-email" class="block text-sm font-semibold mb-2">Your Email (optional)</label>
        <input type="email" id="submitter-email" name="submitterEmail" class="form-input" placeholder="In case we have questions">
      </div>
      <div>
        <button type="submit" class="btn-primary w-full text-center text-lg">Submit Resource</button>
      </div>
    </form>
  </div>
</section>
