---
layout: layouts/base.njk
title: About Us
description: "Meet the founders of The Fullest Project and learn about our mission to support caregivers of individuals with disabilities."
permalink: /about/
---

<!-- Hero -->
<section class="py-16 section-warm">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl font-bold mb-6" style="color: var(--color-primary);">{{ about.hero.heading }}</h1>
    <p class="text-xl" style="color: var(--color-text-light);">
      {{ about.hero.body }}
    </p>
  </div>
</section>

<!-- The Problem -->
<section class="py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold mb-6" style="color: var(--color-primary);">{{ about.problem.heading }}</h2>
    <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-light);">
      {{ about.problem.paragraph1 }}
    </p>
    <p class="text-lg leading-relaxed" style="color: var(--color-text-light);">
      {{ about.problem.paragraph2 }} <strong style="color: var(--color-text);">{{ about.problem.emphasis }}</strong>
    </p>
  </div>
</section>

<!-- Our Approach -->
<section class="py-16 section-warm">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold mb-8" style="color: var(--color-primary);">{{ about.approach.heading }}</h2>
    <div class="space-y-8">
      {% for phase in about.approach.phases %}
      <div class="card p-8">
        <h3 class="text-xl font-bold mb-3" style="color: var(--color-secondary);">{{ phase.title }}</h3>
        <p style="color: var(--color-text-light);">{{ phase.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Meet the Founders -->
<section class="py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-12" style="color: var(--color-primary);">{{ about.founders.heading }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {% for bio in about.founders.bios %}
      <div class="card p-8">
        <h3 class="text-2xl font-bold mb-2" style="color: var(--color-primary);">{{ bio.name }}</h3>
        <p class="text-sm font-semibold mb-4" style="color: var(--color-secondary);">{{ bio.location }}</p>
        <p class="mb-4" style="color: var(--color-text-light);">
          {{ bio.paragraph1 }}
        </p>
        <p class="mb-4" style="color: var(--color-text-light);">
          {{ bio.paragraph2 }}
        </p>
        <p class="text-sm font-semibold" style="color: var(--color-primary);">
          {{ bio.highlight }}
        </p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16" style="background-color: var(--color-primary);">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
    <h2 class="text-3xl font-bold mb-4">{{ about.cta.heading }}</h2>
    <p class="mb-8 opacity-90">{{ about.cta.body }}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="{{ about.cta.primaryCta.url }}" class="btn-secondary no-underline">{{ about.cta.primaryCta.label }}</a>
      <a href="{{ about.cta.secondaryCta.url }}" class="bg-white/20 hover:bg-white/30 text-white px-6 py-3 rounded-lg font-semibold transition-colors no-underline">{{ about.cta.secondaryCta.label }}</a>
    </div>
  </div>
</section>
