---
layout: layouts/base.njk
title: Resource Directory
description: "Find local and national disability resources, programs, foundations, and services."
permalink: /resources/
extraHead: |
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
---

<section class="py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold mb-4 text-center" style="color: var(--color-primary);">Resource Directory</h1>
    <p class="text-center mb-12 max-w-2xl mx-auto" style="color: var(--color-text-light);">
      Browse local and national resources for individuals with disabilities and their caregivers. Use the filters below to find what you need.
    </p>

    <!-- Filters -->
    <div class="card p-6 mb-8">
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-end">
        <div class="flex-grow">
          <label for="search-input" class="block text-sm font-semibold mb-2">Search</label>
          <input type="text" id="search-input" placeholder="Search resources..." class="form-input">
        </div>
        <div>
          <label for="location-filter" class="block text-sm font-semibold mb-2">Location</label>
          <select id="location-filter" class="filter-select">
            <option value="">All Locations</option>
            <option value="National">National</option>
            {% for state in states %}
            <option value="{{ state.name }}">{{ state.name }}</option>
            {% endfor %}
          </select>
        </div>
        <div>
          <label for="area-filter" class="block text-sm font-semibold mb-2">City / Region</label>
          <select id="area-filter" class="filter-select">
            <option value="">All Cities</option>
          </select>
        </div>
        <div>
          <label for="category-filter" class="block text-sm font-semibold mb-2">Category</label>
          <select id="category-filter" class="filter-select">
            <option value="">All Categories</option>
            <option value="influencers">Accessible Influencers</option>
            <option value="gaming">Accessible Gaming</option>
            <option value="clothing">Adaptive Clothing</option>
            <option value="sports">Adaptive Sports & Fitness</option>
            <option value="assistive-tech">Assistive Technology</option>
            <option value="books">Books & Literature</option>
            <option value="camps">Camps & After-School</option>
            <option value="childcare">Childcare</option>
            <option value="community">Community Groups</option>
            <option value="early-intervention">Early Intervention (0-3)</option>
            <option value="education">Education & IEP</option>
            <option value="emergency">Emergency Preparedness</option>
            <option value="employment">Employment</option>
            <option value="dental">Dental & Oral Health</option>
            <option value="disability-language">Disability Language & Advocacy</option>
            <option value="equipment">Equipment & Adaptive Gear</option>
            <option value="faith">Faith Communities</option>
            <option value="financial">Financial Assistance & Benefits</option>
            <option value="government">Government Services</option>
            <option value="grief">Grief & Loss</option>
            <option value="hearing">Hearing & Deaf Resources</option>
            <option value="home-modifications">Home Modifications</option>
            <option value="homeschool">Homeschool & Special Education</option>
            <option value="housing">Housing</option>
            <option value="inclusion">Inclusion Champions</option>
            <option value="incontinence">Incontinence Supplies</option>
            <option value="insurance">Insurance & Appeals</option>
            <option value="legal">Legal & Advocacy</option>
            <option value="medical">Medical Providers</option>
            <option value="mental-health">Mental Health</option>
            <option value="nonprofit">Non-Profits & Foundations</option>
            <option value="nutrition">Nutrition & Feeding</option>
            <option value="recreation">Recreation & Activities</option>
            <option value="respite">Respite Care</option>
            <option value="safety">Safety & Wandering Prevention</option>
            <option value="sensory">Sensory-Friendly Venues</option>
            <option value="service-animals">Service Animals</option>
            <option value="sibling-support">Sibling Support</option>
            <option value="planning">Special Needs Planning</option>
            <option value="switch-adapted">Switch-Adapted Toys & Devices</option>
            <option value="therapy">Therapy Providers (All)</option>
            <option value="therapy-aba">— ABA (Applied Behavior Analysis)</option>
            <option value="therapy-aquatic">— Aquatic Therapy</option>
            <option value="therapy-art">— Art Therapy</option>
            <option value="therapy-equine">— Equine / Hippotherapy</option>
            <option value="therapy-feeding">— Feeding Therapy</option>
            <option value="therapy-music">— Music Therapy</option>
            <option value="therapy-ot">— Occupational Therapy (OT)</option>
            <option value="therapy-pt">— Physical Therapy (PT)</option>
            <option value="therapy-speech">— Speech-Language Therapy</option>
            <option value="therapy-vision">— Vision Therapy</option>
            <option value="transportation">Transportation</option>
            <option value="transition">Transition Services (18-21+)</option>
            <option value="vehicle-mods">Vehicle Modifications</option>
            <option value="vision">Vision & Low Vision</option>
          </select>
        </div>
      </div>
    </div>

    <!-- View toggle + Results count -->
    <div class="flex items-center justify-between mb-6">
      <p id="results-count" class="text-sm" style="color: var(--color-text-light);"></p>
      <div class="flex gap-1 rounded-lg overflow-hidden border" style="border-color: var(--color-primary);">
        <button id="card-view-btn" class="view-toggle-btn px-3 py-1.5 text-sm font-semibold active" style="background-color: var(--color-primary); color: white;" aria-label="Card view">
          Cards
        </button>
        <button id="list-view-btn" class="view-toggle-btn px-3 py-1.5 text-sm font-semibold" style="color: var(--color-primary);" aria-label="List view">
          List
        </button>
        <button id="map-view-btn" class="view-toggle-btn px-3 py-1.5 text-sm font-semibold" style="color: var(--color-primary);" aria-label="Map view">
          Map
        </button>
      </div>
    </div>

    <!-- Map View (hidden by default) -->
    <div id="resource-map" style="display:none; height: 500px; border-radius: 0.75rem; margin-bottom: 1.5rem;"></div>

    <!-- Resource Grid -->
    <div id="resource-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for resource in allResources %}
      <div class="card p-6 resource-card"
           data-location="{{ resource.location }}"
           data-category="{{ resource.category | join(',') }}"
           data-name="{{ resource.name | lower }}"
           data-description="{{ resource.description | lower }}"
           data-area="{{ resource.area | default('') | lower }}">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-lg font-bold" style="color: var(--color-primary);">{{ resource.name }}</h3>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          {% for cat in resource.category %}
          <span class="tag" style="background-color: var(--color-warm); color: var(--color-primary);">{{ cat }}</span>
          {% endfor %}
          <span class="tag" style="background-color: var(--color-accent); color: white;">{{ resource.location }}</span>
          {% if resource.area %}
          <span class="tag" style="background-color: var(--color-warm-light); color: var(--color-text);">{{ resource.area }}</span>
          {% endif %}
        </div>
        <p class="text-sm mb-4" style="color: var(--color-text-light);">{{ resource.description }}</p>
        {% if resource.address %}
        <p class="text-xs mb-1" style="color: var(--color-text-light);">{{ resource.address }}</p>
        {% endif %}
        {% if resource.phone %}
        <p class="text-xs mb-1"><a href="tel:{{ resource.phone }}" style="color: var(--color-accent);">{{ resource.phone }}</a></p>
        {% endif %}
        {% if resource.website %}
        <a href="{{ resource.website }}" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold no-underline inline-block mt-2" style="color: var(--color-secondary);">
          Visit Website &rarr;
        </a>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <!-- Submit CTA -->
    <div class="mt-12 text-center card p-8">
      <h2 class="text-2xl font-bold mb-4" style="color: var(--color-primary);">Know a Resource We're Missing?</h2>
      <p class="mb-6" style="color: var(--color-text-light);">Help us grow our directory by submitting resources you know about.</p>
      <a href="/submit-resource/" class="btn-primary no-underline">Submit a Resource</a>
    </div>

    {% include "components/disclaimer.njk" %}
  </div>
</section>

<script src="/js/resourceFilter.js"></script>
<script src="/js/resourceMap.js"></script>
<style>
  .view-toggle-btn.active {
    background-color: var(--color-primary) !important;
    color: white !important;
  }
  .view-toggle-btn:not(.active) {
    background-color: white;
  }
  /* List view styles */
  #resource-grid.list-view {
    display: flex !important;
    flex-direction: column;
    gap: 0;
  }
  #resource-grid.list-view .resource-card {
    border-radius: 0;
    border-bottom: 1px solid var(--color-warm);
    padding: 1rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  #resource-grid.list-view .resource-card:first-child {
    border-radius: 0.75rem 0.75rem 0 0;
  }
  #resource-grid.list-view .resource-card:last-child {
    border-radius: 0 0 0.75rem 0.75rem;
    border-bottom: none;
  }
  #resource-grid.list-view .resource-card .flex.items-start {
    margin-bottom: 0;
    flex-shrink: 0;
    min-width: 200px;
  }
  #resource-grid.list-view .resource-card .flex.flex-wrap {
    margin-bottom: 0;
  }
  #resource-grid.list-view .resource-card p.text-sm {
    margin-bottom: 0;
    flex: 1;
    min-width: 200px;
  }
  #resource-grid.list-view .resource-card p.text-xs {
    margin-bottom: 0;
  }
  @media (min-width: 768px) {
    #resource-grid.list-view .resource-card {
      flex-wrap: nowrap;
    }
  }
</style>
