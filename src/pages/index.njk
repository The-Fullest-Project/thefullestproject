---
layout: layouts/base.njk
title: Home
description: "A connection hub for caregivers to find national and local special needs and disability information, resources, programs, education, and community."
permalink: /
---

<!-- Hero Section -->
<section class="hero-gradient text-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6" style="font-family: var(--font-heading);">
      {{ homepage.hero.heading }}
    </h1>
    <p class="text-xl sm:text-2xl mb-8 max-w-3xl mx-auto opacity-90">
      {{ homepage.hero.subheading }}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="{{ homepage.hero.primaryCta.url }}" class="btn-secondary text-lg px-8 py-4 no-underline">{{ homepage.hero.primaryCta.label }}</a>
      <a href="{{ homepage.hero.secondaryCta.url }}" class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors no-underline">{{ homepage.hero.secondaryCta.label }}</a>
    </div>
  </div>
</section>

<!-- Mission Statement -->
<section class="py-16 section-warm">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold mb-6" style="color: var(--color-primary);">{{ homepage.mission.heading }}</h2>
    <p class="text-lg leading-relaxed" style="color: var(--color-text-light);">
      {{ homepage.mission.body }} <strong style="color: var(--color-text);">{{ homepage.mission.emphasis }}</strong>
    </p>
  </div>
</section>

<!-- Section Cards -->
<section class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-12" style="color: var(--color-primary);">{{ homepage.features.heading }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for card in homepage.features.cards %}
      <a href="{{ card.url }}" class="card p-8 no-underline block" style="color: var(--color-text);">
        <div class="text-4xl mb-4" aria-hidden="true">{{ card.icon }}</div>
        <h3 class="text-xl font-bold mb-3" style="color: var(--color-primary);">{{ card.title }}</h3>
        <p style="color: var(--color-text-light);">{{ card.description }}</p>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Stories & News Feed -->
<section class="py-16 section-warm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-primary);">{{ homepage.stories.heading }}</h2>
    <p class="text-center mb-12" style="color: var(--color-text-light);">{{ homepage.stories.subheading }}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for story in stories | limit(3) %}
      <article class="card overflow-hidden">
        <div class="p-6">
          <span class="tag" style="background-color: var(--color-warm); color: var(--color-primary);">{{ story.category or "Story" }}</span>
          <h3 class="text-lg font-bold mt-3 mb-2">
            <a href="{{ story.sourceUrl }}" target="_blank" rel="noopener noreferrer" class="no-underline" style="color: var(--color-text);">{{ story.title }}</a>
          </h3>
          <p class="text-sm mb-3" style="color: var(--color-text-light);">{{ story.excerpt }}</p>
          <div class="flex items-center justify-between">
            <span class="text-xs" style="color: var(--color-text-light);">{{ story.sourceName }}</span>
            <time class="text-xs" style="color: var(--color-text-light);">{{ story.date }}</time>
          </div>
        </div>
      </article>
      {% else %}
      <div class="card p-6 text-center lg:col-span-3">
        <p style="color: var(--color-text-light);">{{ homepage.stories.emptyMessage }}</p>
        <a href="/contact/" class="btn-primary mt-4 inline-block no-underline">{{ homepage.stories.emptyCtaLabel }}</a>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-14">
      <a href="/blog/" class="btn-secondary no-underline">{{ homepage.stories.browseAllLabel }} &rarr;</a>
    </div>
  </div>
</section>

<!-- Organization Spotlight -->
{% set featuredSpotlights = spotlights | filterFeatured | limit(1) %}
{% if featuredSpotlights.length %}
<section class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-primary);">{{ homepage.spotlight.heading }}</h2>
    <p class="text-center mb-12" style="color: var(--color-text-light);">{{ homepage.spotlight.subheading }}</p>
    <div class="max-w-lg mx-auto">
      {% set spotlight = featuredSpotlights[0] %}
      {% include "components/spotlight-card.njk" %}
    </div>
    <div class="text-center mt-8">
      <a href="/spotlights/" class="btn-secondary no-underline">{{ homepage.spotlight.viewAllLabel }}</a>
    </div>
  </div>
</section>
{% endif %}

<!-- Newsletter CTA -->
<section class="py-16" style="background-color: var(--color-primary);">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
    <h2 class="text-3xl font-bold mb-4" style="font-family: var(--font-heading);">{{ homepage.newsletter.heading }}</h2>
    <p class="mb-8 opacity-90">{{ homepage.newsletter.body }}</p>
    <form action="https://formspree.io/f/{{ site.formspree.newsletter }}" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      data-newsletter data-worker-url="{{ site.adminWorkerUrl }}/newsletter">
      <label for="home-email" class="sr-only">Email address</label>
      <input type="email" id="home-email" name="email" placeholder="{{ homepage.newsletter.placeholder }}" required
        class="form-input flex-grow" style="background-color: white; color: var(--color-text);">
      <button type="submit" class="btn-secondary whitespace-nowrap">{{ homepage.newsletter.buttonLabel }}</button>
    </form>
  </div>
</section>

<!-- Nationwide Coverage -->
<section class="py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold mb-4" style="color: var(--color-primary);">{{ homepage.coverage.heading }}</h2>
    <p class="mb-8" style="color: var(--color-text-light);">{{ homepage.coverage.body }}</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
      <div class="card p-6 text-center">
        <div class="text-3xl font-extrabold mb-1" style="color: var(--color-secondary);">{{ allResources | length }}+</div>
        <p class="text-sm" style="color: var(--color-text-light);">{{ homepage.coverage.statResourcesLabel }}</p>
      </div>
      <div class="card p-6 text-center">
        <div class="text-3xl font-extrabold mb-1" style="color: var(--color-secondary);">{{ homepage.coverage.statLocationsValue }}</div>
        <p class="text-sm" style="color: var(--color-text-light);">{{ homepage.coverage.statLocationsLabel }}</p>
      </div>
      <div class="card p-6 text-center">
        <div class="text-3xl font-extrabold mb-1" style="color: var(--color-secondary);">{{ homepage.coverage.statCategoriesValue }}</div>
        <p class="text-sm" style="color: var(--color-text-light);">{{ homepage.coverage.statCategoriesLabel }}</p>
      </div>
    </div>
    <a href="/resources/" class="btn-primary no-underline text-lg px-8 py-4">{{ homepage.coverage.ctaLabel }}</a>
  </div>
</section>
