<footer class="mt-16" style="background-color: var(--color-primary-dark); color: white;" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- About -->
      <div>
        <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">The Fullest Project</h3>
        <p class="text-sm opacity-80 leading-relaxed">
          A connection hub for caregivers to find disability information, resources, programs, education, and community.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Explore</h3>
        <ul class="space-y-2 text-sm opacity-80">
          <li><a href="/resources/" class="hover:opacity-100 no-underline" style="color: white;">Resource Directory</a></li>
          <li><a href="/therapy-guide/" class="hover:opacity-100 no-underline" style="color: white;">Therapy Guide</a></li>
          <li><a href="/adaptive-equipment/" class="hover:opacity-100 no-underline" style="color: white;">Adaptive Equipment</a></li>
          <li><a href="/school-iep/" class="hover:opacity-100 no-underline" style="color: white;">School & IEP</a></li>
          <li><a href="/blog/" class="hover:opacity-100 no-underline" style="color: white;">Blog</a></li>
          <li><a href="/podcast/" class="hover:opacity-100 no-underline" style="color: white;">Podcast</a></li>
          <li><a href="/spotlights/" class="hover:opacity-100 no-underline" style="color: white;">Spotlights</a></li>
        </ul>
      </div>

      <!-- Get Involved -->
      <div>
        <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Get Involved</h3>
        <ul class="space-y-2 text-sm opacity-80">
          <li><a href="/gigs/" class="hover:opacity-100 no-underline" style="color: white;">Gig Board</a></li>
          <li><a href="/submit-resource/" class="hover:opacity-100 no-underline" style="color: white;">Submit a Resource</a></li>
          <li><a href="/quick-submit/" class="hover:opacity-100 no-underline" style="color: white;">Quick Submit Tool</a></li>
          <li><a href="/services/" class="hover:opacity-100 no-underline" style="color: white;">Our Services</a></li>
          <li><a href="/donate/" class="hover:opacity-100 no-underline" style="color: white;">Donate</a></li>
          <li><a href="/contact/" class="hover:opacity-100 no-underline" style="color: white;">Contact Us</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Stay Connected</h3>
        <p class="text-sm opacity-80 mb-4">Get updates on new resources and community news.</p>
        <form action="https://formspree.io/f/{{ site.formspree.newsletter }}" method="POST" class="flex flex-col gap-2">
          <label for="footer-email" class="sr-only">Email address</label>
          <input type="email" id="footer-email" name="email" placeholder="Your email" required
            class="form-input text-sm" style="background-color: white; color: var(--color-text);">
          <fieldset class="flex flex-col gap-1 text-xs opacity-80 mt-1">
            <legend class="sr-only">Subscription preferences</legend>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="weekly_resources" value="yes" checked class="rounded">
              Weekly Resource Updates
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="monthly_mailer" value="yes" class="rounded">
              Monthly Mailer Subscription
            </label>
          </fieldset>
          <button type="submit" class="btn-secondary text-sm text-center mt-1">Subscribe</button>
        </form>
      </div>
    </div>

    <!-- Social Links -->
    {% if site.social.instagram or site.social.facebook %}
    <div class="mt-8 flex justify-center gap-6">
      {% if site.social.instagram %}
      <a href="{{ site.social.instagram }}" target="_blank" rel="noopener noreferrer"
         aria-label="Follow us on Instagram" class="opacity-80 hover:opacity-100" style="color: white;">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      {% endif %}
      {% if site.social.facebook %}
      <a href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer"
         aria-label="Follow us on Facebook" class="opacity-80 hover:opacity-100" style="color: white;">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      {% endif %}
    </div>
    {% endif %}

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/20 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm opacity-60">
      <p>&copy; {{ "" | dateFormat | truncate(4, "") }}{% set year = "now" %}2026 The Fullest Project. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy/" class="hover:opacity-100 no-underline" style="color: white;">Privacy Policy</a>
        <a href="/terms/" class="hover:opacity-100 no-underline" style="color: white;">Terms of Use</a>
        <a href="/accessibility/" class="hover:opacity-100 no-underline" style="color: white;">Accessibility</a>
      </div>
    </div>
  </div>
</footer>
